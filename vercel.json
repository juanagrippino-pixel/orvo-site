{
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/site.webmanifest",
      "dest": "/site.webmanifest"
    },
    {
      "src": "/software-gestion-pymes",
      "dest": "/software-gestion-pymes.html"
    },
    {
      "src": "/software-gestion-pymes.html",
      "dest": "/software-gestion-pymes.html"
    },
    {
      "src": "/agentes-ia-pymes",
      "dest": "/agentes-ia-pymes.html"
    },
    {
      "src": "/agentes-ia-pymes.html",
      "dest": "/agentes-ia-pymes.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
